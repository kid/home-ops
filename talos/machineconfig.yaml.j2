---
version: v1alpha1
machine:
  token: op://home-ops/talos/MACHINE_TOKEN
  ca:
    crt: op://home-ops/talos/MACHINE_CA_CRT
    {% if ENV.IS_CONTROLLER %}
    key: op://home-ops/talos/MACHINE_CA_KEY
    {% endif %}
  kubelet:
    image: ghcr.io/siderolabs/kubelet:v1.35.0
    defaultRuntimeSeccompProfileEnabled: true
    disableManifestsDirectory: true
    nodeIP:
      validSubnets:
        - 10.0.40.0/24
  install:
    disk: /dev/sda
    image: factory.talos.dev/installer/ae6e6cc41d91b5d3abd80062899cec7eba46c819e14684a9b483cfd4616facc2:v1.12.6
    wipe: false
    grubUseUKICmdline: true
  features:
    diskQuotaSupport: true
    kubePrism:
      enabled: true
      port: 7445
    hostDNS:
      enabled: true
      forwardKubeDNSToHost: true
      resolveMemberNames: true
  kernel:
    modules:
      - name: drbd
        parameters:
          - usermode_helper=disabled
      - name: drbd_transport_tcp
      - name: zfs
  {% if ENV.IS_CONTROLLER %}
  nodeLabels:
    node.kubernetes.io/exclude-from-external-load-balancers: ""
  {% endif %}
cluster:
  id: op://home-ops/talos/CLUSTER_ID
  secret: op://home-ops/talos/CLUSTER_SECRET
  token: op://home-ops/talos/CLUSTER_TOKEN
  secretboxEncryptionSecret: op://home-ops/talos/CLUSTER_SECRETBOXENCRYPTIONSECRET
  ca:
    crt: op://home-ops/talos/CLUSTER_CA_CRT
    {% if ENV.IS_CONTROLLER %}
    key: op://home-ops/talos/CLUSTER_CA_KEY
    {% endif %}
  controlPlane:
    endpoint: https://k8s.internal:6443
  clusterName: prd
  allowSchedulingOnControlPlanes: true
  network:
    cni:
      name: none
    dnsDomain: cluster.local
    podSubnets:
      - 10.42.0.0/16
    serviceSubnets:
      - 10.43.0.0/16
  discovery:
    enabled: false
  {% if ENV.IS_CONTROLLER %}
  aggregatorCA:
    crt: op://home-ops/talos/CLUSTER_AGGREGATORCA_CRT
    key: op://home-ops/talos/CLUSTER_AGGREGATORCA_KEY
  serviceAccount:
    key: op://home-ops/talos/CLUSTER_SERVICEACCOUNT_KEY
  apiServer:
    certSANs:
      - "127.0.0.1"
      - "10.0.42.10"
      - "k8s.internal"
      - "talos-cp-1.talos.home.kidibox.net"
      - "talos-cp-2.talos.home.kidibox.net"
      - "talos-cp-3.talos.home.kidibox.net"
    image: registry.k8s.io/kube-apiserver:v1.35.0
    admissionControl:
      - name: PodSecurity
        configuration:
          apiVersion: pod-security.admission.config.k8s.io/v1alpha1
          kind: PodSecurityConfiguration
          defaults:
            audit: restricted
            audit-version: latest
            enforce: baseline
            enforce-version: latest
            warn: restricted
            warn-version: latest
          exemptions:
            namespaces:
              - kube-system
            runtimeClasses: []
            usernames: []
    auditPolicy:
      apiVersion: audit.k8s.io/v1
      kind: Policy
      rules:
        - level: Metadata
  controllerManager:
    image: registry.k8s.io/kube-controller-manager:v1.35.0
  scheduler:
    image: registry.k8s.io/kube-scheduler:v1.35.0
  proxy:
    disabled: true
  coreDNS:
    disabled: false
  etcd:
    advertisedSubnets:
      - 10.0.40.0/24
    ca:
      crt: op://home-ops/talos/CLUSTER_ETCD_CA_CRT
      key: op://home-ops/talos/CLUSTER_ETCD_CA_KEY
  {% endif %}
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: net0
clientIdentifier: mac
---
# https://github.com/siderolabs/talos/pull/9200#issuecomment-2805269653
apiVersion: v1alpha1
kind: LinkConfig
name: lo
addresses:
  - address: 169.254.116.108/32
