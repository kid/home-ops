{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
  ],
  ignorePaths: [
    '**/resources/**',
  ],
  flux: {
    managerFilePatterns: ['/\\.yaml(?:\\.j2)?$/'],
  },
  "helm-values": {
    managerFilePatterns: ['/\\.yaml(?:\\.j2)?$/'],
  },
  kubernetes: {
    managerFilePatterns: ['/\\.yaml(?:\\.j2)?$/'],
  },
}
