{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>kid/home-ops//.renovate/groups.json5",
    "github>kid/home-ops//.renovate/labels.json5",
    "github>kid/home-ops//.renovate/overrides.json5",
    "github>kid/home-ops//.renovate/semanticCommits.json5",
    ":automergeBranch",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(Europe/Brussels)",
  ],
  ignorePaths: [
    '**/resources/**',
  ],
  suppressNotifications: [
    "prEditedNotification",
    "prIgnoreNotification",
  ],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"],
  },
}
